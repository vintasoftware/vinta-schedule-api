# Container env: used by docker-compose (env_file: .env.docker).
# Service hostnames point at the compose service names.
# Copy to .env.docker.
DJANGO_SETTINGS_MODULE=vinta_schedule_api.settings.local
CELERY_BROKER_URL=amqp://broker:5672//
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
REDIS_URL=redis://result:6379
DATABASE_URL=postgres://vinta_schedule_api:password@db:5432/vinta_schedule_api
FLOCI_ENDPOINT=http://floci:4566
FLOCI_EXTERNAL_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=vinta_schedule
PYTHONBREAKPOINT=ipdb.set_trace
SALT_KEY=TEST_SALT_KEY_123
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWILIO_ACCOUNT_SID=
# Preferred: API Key auth. Set both. Falls back to TWILIO_AUTH_TOKEN if unset.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# Legacy auth-token auth (not recommended). Used only if API key vars are unset.
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=
TWILIO_DEFAULT_BROADCAST_NUMBERS=
# Per-environment rollout gate for SMS phone verification. Keep False until
# Twilio approves the messaging profile for this environment.
ACCOUNT_PHONE_VERIFICATION_ENABLED=False
# Shared secret used to verify MercadoPago's `x-signature` webhook header. A
# guessable default (e.g. "test") would give local signature verification a
# working secret an attacker can trivially replicate; CHANGEME fails closed
# instead, matching the empty default in settings/base.py.
MERCADOPAGO_WEBHOOK_SECRET=CHANGEME
# Stripe secret API key. No organization is routed onto Stripe yet, so this is
# unused in practice until Phase 9 — CHANGEME is a safe placeholder either way.
STRIPE_SECRET_KEY=CHANGEME
# Shared secret used to verify Stripe's `Stripe-Signature` webhook header. Same
# fail-closed rationale as MERCADOPAGO_WEBHOOK_SECRET, above.
STRIPE_WEBHOOK_SECRET=CHANGEME
